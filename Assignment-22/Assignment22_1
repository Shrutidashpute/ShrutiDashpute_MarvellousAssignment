from multiprocessing import Pool

def SumSquare(No):

    Sum = 0

    for i in range(1, No + 1):
        Sum = Sum + (i * i)

    return Sum

def main():

    Data = []

    Size = int(input("Enter number of elements : "))

    for i in range(Size):
        No = int(input("Enter number : "))
        Data.append(No)

    print("Input List :", Data)

    P = Pool()

    Result = P.map(SumSquare, Data)

    print("Output :", Result)

if __name__ == "__main__":
    main()