from multiprocessing import Pool
import time

def SumSquare(No):

    Sum = 0

    for i in range(1, No + 1):
        Sum = Sum + (i * i)

    return Sum

def main():

    Data = [100000, 200000, 300000, 400000]

    Start = time.time()

    P = Pool()

    Result = P.map(SumSquare, Data)

    End = time.time()

    print("Results :", Result)

    print("Execution Time :", End - Start)

if __name__ == "__main__":
    main()