def Minimum(Data):

    Min = Data[0]

    for Value in Data:
        if Value < Min:
            Min = Value

    return Min

def main():

    Size = int(input("Number of elements : "))
    Data = []

    for i in range(Size):
        No = int(input("Input Elements : "))
        Data.append(No)

    print("Input Elements :", Data)

    Result = Minimum(Data)

    print("Minimum number is :", Result)

if __name__ == "__main__":
    main()