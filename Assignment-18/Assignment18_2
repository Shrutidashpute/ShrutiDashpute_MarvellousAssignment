def Maximum(Data):

    Max = Data[0]

    for Value in Data:
        if Value > Max:
            Max = Value

    return Max

def main():

    Size = int(input("Number of elements : "))
    Data = []

    for i in range(Size):
        No = int(input("Input Elements : "))
        Data.append(No)

    print("Input Elements :", Data)

    Result = Maximum(Data)

    print("Maximum number is :", Result)

if __name__ == "__main__":
    main()