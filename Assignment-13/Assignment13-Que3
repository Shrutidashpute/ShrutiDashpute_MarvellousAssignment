def CheckPerfectNumber(No):
    Sum = 0

    for i in range(1, No):
        if No % i == 0:
            Sum = Sum + i

    if Sum == No:
        print("Perfect Number")
    else:
        print("Not a Perfect Number")

def main():
    No = int(input("Enter a number: "))
    CheckPerfectNumber(No)

if __name__ == "__main__":
    main()