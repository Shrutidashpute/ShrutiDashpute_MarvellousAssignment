import schedule
import datetime
import time

def CreateLog():
    CurrentTime = datetime.datetime.now()

    FileName = "MarvellousLog_" + \
               CurrentTime.strftime("%d_%m_%Y_%H_%M_%S") + ".txt"

    FileObj = open(FileName, "w")

    FileObj.write("Log file created successfully\n")
    FileObj.write("Creation Time : " +
                  CurrentTime.strftime("%d-%m-%Y %I:%M:%S %p"))

    FileObj.close()

    print(FileName, "created")

def main():
    schedule.every(10).minutes.do(CreateLog)

    while True:
        schedule.run_pending()
        time.sleep(1)

if __name__ == "__main__":
    main()