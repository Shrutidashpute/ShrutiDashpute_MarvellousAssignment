def SumDigits(No):
    Sum = 0

    while No != 0:
        Digit = No % 10
        Sum = Sum + Digit
        No = No // 10

    return Sum

def main():
    No = int(input("Enter a number: "))
    Result = SumDigits(No)
    print("Sum of digits:", Result)

if __name__ == "__main__":
    main()