import schedule
import datetime
import time

def DisplayDateTime():
    print("Current Date and Time :",datetime.datetime.now().strftime("%d-%m-%Y %I:%M:%S %p"))

def main():
    schedule.every(1).minute.do(DisplayDateTime)

    while True:
        schedule.run_pending()
        time.sleep(1)

if __name__ == "__main__":
    main()