def ChkGreater(x, y):
    if x > y:
        print(x, " is greater ")
    else:
        print(y, " is greater ")

def main():
    print("Enter first number :")
    x = int(input())
    
    print("Enter second number :")
    y = int(input())
    
    ChkGreater(x, y)

if __name__ == "__main__":
    main()  