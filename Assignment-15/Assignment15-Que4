from functools import reduce

Add = lambda x, y: x + y

def main():

    Size = int(input("Enter number of elements: "))

    Data = []

    for i in range(Size):
        No = int(input("Enter a number: "))
        Data.append(No)

    Result = reduce(Add, Data)

    print("Addition of all elements:", Result)

if __name__ == "__main__":
    main()