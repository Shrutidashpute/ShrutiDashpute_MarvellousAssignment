Square = lambda No1 : No1 * No1   

def main():

    Size = int(input("Enter number of elements: "))

    Data = []

    for i in range(Size):
        No1 = int(input("Enter a number: "))
        Data.append(No1)

    SquareList = list(map(Square, Data))

    print("Input Data List :", Data)
    print("Data After Map List   :", SquareList)

if __name__ == "__main__":
    main()