GreateFive = lambda x: len(x) > 5

def main():

    Data = ["Python", "C", "Java", "Marvellous", "Lambda", "Filter", "Reduce", "Map"]

    Result = list(filter(GreateFive, Data))

    print("Original List :", Data)
    print("Filtered List :", Result)

if __name__ == "__main__":
    main()