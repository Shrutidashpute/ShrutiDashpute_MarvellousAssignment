CheckOdd = lambda No1 : (No1 % 2 != 0)

def main():

    Size = int(input("Enter number of elements: "))

    Data = []

    for i in range(Size):
        No1 = int(input("Enter a number: "))
        Data.append(No1)

    OddList = list(filter(CheckOdd, Data))

    print("Input Data List :", Data)
    print("Data After Filter :", OddList)

if __name__ == "__main__":
    main()