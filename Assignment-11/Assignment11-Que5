def ChkPalindromeNumber(No):
    Original = No
    Reverse = 0

    while No != 0:
        Digit = No % 10
        Reverse = Reverse * 10 + Digit
        No = No // 10

    if Original == Reverse:
        print("Palindrome Number")
    else:
        print("Not a Palindrome Number")

def main():
    No = int(input("Enter a number: "))
    ChkPalindromeNumber(No)

if __name__ == "__main__":
    main()